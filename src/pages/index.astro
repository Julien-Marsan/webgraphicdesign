---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Accueil"
  description="Agence web et design graphique à Salles sur l'Hers. Sites WordPress, WooCommerce, identité visuelle et supports print. Devis gratuit."
>

  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <!-- Left content -->
        <div class="hero-content">
          <div class="hero-tag">
            <span class="dot"></span>
            Agence Digitale · Salles sur l'Hers
          </div>
          <h1>
            Attirez plus<br/>
            <span class="text-gradient">de clients avec un site web performant.</span>
          </h1>
          <p class="hero-desc">
            Des sites web performants, des identités visuelles mémorables et des supports print qui marquent les esprits. Basé à Salles sur l'Hers, près de Villefranche de Lauragais.
          </p>
          <div class="hero-actions">
            <a href="/services" class="btn btn-primary">
              Mes services
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
            <a href="/contact" class="btn btn-outline">Devis gratuit</a>
          </div>
          <!-- Trust badges -->
          <div class="hero-badges">
            <div class="badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              <span>SEO Optimisé</span>
            </div>
            <div class="badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>Livraison Rapide</span>
            </div>
          </div>
        </div>

        <!-- Right visual -->
        <div class="hero-visual">
          <div class="hero-mockup-wrap">
            <div class="browser-mockup">
              <div class="browser-bar">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
                <div class="browser-url">webgraphicdesign.fr</div>
              </div>
              <div class="browser-content">
                <div class="mock-nav"></div>
                <div class="mock-hero">
                  <div class="mock-hero-text">
                    <div class="mock-line wide"></div>
                    <div class="mock-line medium"></div>
                    <div class="mock-line short"></div>
                    <div class="mock-btn"></div>
                  </div>
                  <div class="mock-hero-img"></div>
                </div>
                <div class="mock-cards">
                  <div class="mock-card"></div>
                  <div class="mock-card"></div>
                  <div class="mock-card"></div>
                </div>
              </div>
            </div>
            <!-- Floating chips -->
            <div class="chip chip-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#21759B"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
              WordPress
            </div>
            <div class="chip chip-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#7C3AED"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Intelligence Artificielle
            </div>
            <div class="chip chip-3">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#EC4899"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              SEO
            </div>
            <div class="floating-stat">
              <span class="stat-num">+100</span>
              <span class="stat-lab">Projets</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ===================== APERÇU IA ===================== -->
  <section class="apercu-section" hidden style="display:none">
    <div class="container">
      <div class="apercu-inner" data-animate>
        <div class="apercu-left">
          <div class="apercu-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#7C3AED"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Nouveauté — Propulsé par l'IA
          </div>
          <h2>Visualisez votre futur site<br/><span class="text-gradient">avant même de me contacter</span></h2>
          <p>Entrez simplement votre activité et mon outil génère en quelques secondes un aperçu visuel personnalisé de votre futur site web — avec une estimation de budget. Gratuit, sans inscription.</p>
          <ul class="apercu-benefits">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Aperçu personnalisé selon votre secteur
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Estimation de budget instantanée
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              100% gratuit — résultat en quelques secondes
            </li>
          </ul>
          <a href="/apercu" class="btn-apercu-main">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Générer mon aperçu gratuit
          </a>
        </div>
        <div class="apercu-right">
          <div class="apercu-card">
            <div class="apercu-card-header">
              <span class="apercu-card-tag">Votre activité</span>
              <div class="apercu-input-mock">Boulangerie artisanale à Toulouse…</div>
            </div>
            <div class="apercu-card-result">
              <div class="apercu-result-bar"></div>
              <div class="apercu-result-lines">
                <div class="apercu-line w80"></div>
                <div class="apercu-line w60"></div>
              </div>
              <div class="apercu-result-blocks">
                <div class="apercu-block"></div>
                <div class="apercu-block"></div>
                <div class="apercu-block"></div>
              </div>
            </div>
            <div class="apercu-card-footer">
              <div class="apercu-budget">
                <span class="apercu-budget-label">Estimation budget</span>
                <span class="apercu-budget-value">800 € – 1 500 €</span>
              </div>
              <div class="apercu-ai-badge">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#7C3AED"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Généré par IA
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header" data-animate>
        <span class="section-tag">Ce que je propose</span>
        <h2>Mes Services</h2>
        <p>Des solutions numériques et visuelles complètes pour aider votre entreprise à se démarquer et prospérer dans le monde digital.</p>
      </div>

      <div class="services-grid">
        <!-- Site Web -->
        <a href="/services#web" class="service-card" data-animate data-animate-delay="1">
          <div class="service-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div class="service-content">
            <h3>Site Web</h3>
            <p>Sites WordPress sur mesure, boutiques WooCommerce performantes et solutions SEO pour maximiser votre visibilité en ligne.</p>
            <ul class="service-tags">
              <li>WordPress</li>
              <li>WooCommerce</li>
              <li>SEO</li>
            </ul>
          </div>
          <div class="service-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <!-- Design -->
        <a href="/services#design" class="service-card featured" data-animate data-animate-delay="2">
          <div class="service-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="3.5"/><circle cx="6.5" cy="15.5" r="3.5"/><circle cx="17" cy="17" r="3"/><line x1="13.5" y1="10" x2="6.5" y2="12"/></svg>
          </div>
          <div class="service-content">
            <h3>Design Graphique</h3>
            <p>Identité visuelle percutante, logo mémorable, charte graphique complète et éléments visuels qui racontent votre histoire.</p>
            <ul class="service-tags">
              <li>Logo</li>
              <li>Identité visuelle</li>
              <li>Branding</li>
            </ul>
          </div>
          <div class="service-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <!-- Print -->
        <a href="/services#print" class="service-card" data-animate data-animate-delay="3">
          <div class="service-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          </div>
          <div class="service-content">
            <h3>Supports Print</h3>
            <p>Flyers, affiches, brochures, cartes de visite et tous vos supports de communication imprimés, conçus avec soin.</p>
            <ul class="service-tags">
              <li>Flyers</li>
              <li>Brochures</li>
              <li>Cartes de visite</li>
            </ul>
          </div>
          <div class="service-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      </div>

      <div class="services-cta" data-animate>
        <a href="/services" class="btn btn-ghost">
          Voir tous mes services
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item" data-animate>
          <span class="stat-number">+100</span>
          <span class="stat-label">Projets réalisés</span>
        </div>
        <div class="stat-item" data-animate data-animate-delay="1">
          <span class="stat-number">100%</span>
          <span class="stat-label">Clients satisfaits</span>
        </div>
        <div class="stat-item" data-animate data-animate-delay="2">
          <span class="stat-number">+15</span>
          <span class="stat-label">Ans d'expérience</span>
        </div>
        <div class="stat-item" data-animate data-animate-delay="3">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Support client</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section class="section about-section">
    <div class="container">
      <div class="about-inner">
        <div class="about-visual" data-animate>
          <div class="about-image-wrap">
            <img src="/projet-occitanie-btp.svg" alt="Projet Occitanie BTP" class="about-image" />
            <!-- Floating card -->
            <div class="about-float-card">
              <div class="float-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <strong>Projet livré</strong>
                <span>Site Vitrine · Près de Castelnaudary</span>
              </div>
            </div>
          </div>
        </div>

        <div class="about-content" data-animate data-animate-delay="2">
          <span class="section-tag">Qui suis-je</span>
          <h2>Passionné par le<br/><span class="text-gradient">Design & le Code</span></h2>
          <div class="divider"></div>
          <p>
            Moi, c'est Julien. Je crois que votre présence en ligne doit être aussi unique que votre entreprise. Webdesigner et webmaster senior avec plus de 15 ans d'expérience, je crée des expériences numériques sur mesure qui allient esthétique et performance.
          </p>
          <p style="margin-top: 16px;">
            Du concept initial au lancement final, je transforme votre vision en réalité avec les meilleures technologies web actuelles. Basé près de Villefranche de Lauragais, j'accompagne des entreprises de toutes tailles dans leur développement digital.
          </p>
          <div class="about-values">
            <div class="value-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Conception sur mesure</span>
            </div>
            <div class="value-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Performance & SEO optimisés</span>
            </div>
            <div class="value-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Accompagnement continu</span>
            </div>
            <div class="value-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Délais respectés</span>
            </div>
          </div>
          <a href="/a-propos" class="btn btn-primary" style="margin-top: 8px;">
            En savoir plus
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA BANNER ===================== -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-inner" data-animate>
        <div class="cta-content">
          <h2>Prêt à démarrer votre projet ?</h2>
          <p>Dites-moi ce que vous imaginez, je le crée. Devis gratuit sous 24h.</p>
        </div>
        <div class="cta-actions">
          <a href="/contact" class="btn btn-white">
            Me contacter
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
          <a href="tel:+33781041953" class="btn" style="color:rgba(255,255,255,0.8); border: 2px solid rgba(255,255,255,0.25);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Appeler directement
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ========= HERO ========= */
  .hero {
    padding: 100px 0 80px;
    background: linear-gradient(145deg, #fafbff 0%, #f5f0ff 40%, #fdf2f8 100%);
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--primary);
    background: rgba(124,58,237,0.08);
    padding: 7px 14px;
    border-radius: 100px;
    margin-bottom: 24px;
  }
  .hero-tag .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--primary);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-content h1 { margin-bottom: 24px; }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 480px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  /* ========= APERÇU IA ========= */
  .apercu-section {
    padding: var(--section-py) 0;
    background: linear-gradient(145deg, #0f0a1e 0%, #1a0533 50%, #0f0a1e 100%);
    position: relative;
    overflow: hidden;
  }
  .apercu-section::before {
    content: '';
    position: absolute;
    top: -150px; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 400px;
    background: radial-gradient(ellipse, rgba(124,58,237,0.25) 0%, transparent 70%);
    pointer-events: none;
  }

  .apercu-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
    position: relative;
  }

  .apercu-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    color: #a78bfa;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
    letter-spacing: 0.02em;
  }

  .apercu-left h2 {
    color: white;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .apercu-left p {
    color: rgba(255,255,255,0.6);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .apercu-benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 36px;
  }
  .apercu-benefits li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
  }

  .btn-apercu-main {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--gradient);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    padding: 16px 32px;
    border-radius: 100px;
    box-shadow: 0 6px 24px rgba(124,58,237,0.5);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-apercu-main:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(124,58,237,0.6);
    color: white;
  }

  /* Aperçu card mockup */
  .apercu-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    overflow: hidden;
    backdrop-filter: blur(10px);
  }

  .apercu-card-header {
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .apercu-card-tag {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 10px;
  }
  .apercu-input-mock {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    font-style: italic;
  }

  .apercu-card-result {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .apercu-result-bar {
    height: 28px;
    background: rgba(124,58,237,0.4);
    border-radius: 6px;
  }
  .apercu-result-lines { display: flex; flex-direction: column; gap: 8px; }
  .apercu-line { height: 8px; border-radius: 4px; background: rgba(255,255,255,0.1); }
  .apercu-line.w80 { width: 80%; }
